# Authentication / 认证
SYSTEM_PASSWORD=
JWT_SECRET=

# AI providers / AI 提供商
OPENAI_API_KEY=
# Optional OpenAI-compatible relay endpoint, for example https://api.example.com/v1
# 可选 OpenAI 兼容中转端点，例如 https://api.example.com/v1
OPENAI_API_BASE_URL=
ANTHROPIC_API_KEY=
# Optional Anthropic-compatible relay endpoint.
# 可选 Anthropic 兼容中转端点。
ANTHROPIC_API_BASE_URL=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=
ACTIVE_AI_PROVIDER_ID=

# MVP defaults (optional -- used by the default daily-digest curator)
# MVP 默认配置（可选，供默认每日摘要精选 Agent 使用）
# Set the provider/model pair to Anthropic when using ANTHROPIC_API_KEY instead.
# 使用 ANTHROPIC_API_KEY 时，请改为匹配的 Anthropic provider/model 组合。
DEFAULT_CURATION_PROVIDER_ID=default-openai
DEFAULT_CURATION_MODEL=gpt-4o-mini
DEFAULT_CURATION_TEMPERATURE=0.3
DEFAULT_DIGEST_TARGETS=feishu_bot,wecom_bot
DEFAULT_DIGEST_TOP_N=5
DEFAULT_DIGEST_FETCH_DAYS=2
DEFAULT_DIGEST_ADAPTER_IDS=rss-adapter

# Publishers / 发布渠道
FEISHU_WEBHOOK=
FEISHU_SECRET=
WECOM_WEBHOOK=

# Runtime / 运行时
DB_PATH=data/database.sqlite
LOG_LEVEL=INFO
# Optional outbound proxy for OpenAI and Anthropic, for example http://127.0.0.1:7890
# 可选 OpenAI 和 Anthropic 出站代理，例如 http://127.0.0.1:7890
HTTP_PROXY=
